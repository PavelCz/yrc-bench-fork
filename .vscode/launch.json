{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gather Rollouts Coinrun",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gather_rollouts.py",
            "args": [
                "-c", "configs/procgen_ood.yaml",
                "-en", "coinrun",
                "-n", "debug_gather_rollouts",
                "-num_rollouts", "8",
                "-use_bg", "True",
                "-wandb_project", "yrc-debug",
                "-wandb_mode", "offline",
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "SM_OUTPUT_DIR": "/home/pavel/data/goal-misgen/tmp/experiments"
            }
        },
        {
            "name": "Train No Threshold Coinrun OOD",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "args": [
                "-c", "configs/procgen_ood.yaml",
                // "-c", "configs/procgen_ae_hard.yaml",
                "-n", "debug_ood_deepsvdd",
                "-en", "coinrun",
                // "-cp_method", "AutoEncoder",
                // "-cp_method", "Autoencoder",
                "-cp_method", "DeepSVDD",
                "-query_cost", "0",
                "-cp_epoch", "2",
                "-over",
                "-num_rollouts", "2",
                "-num_envs", "2",
                "-cp_latent_dim", "128",
                "-use_bg", "True",
                "-wandb_project", "yrc-debug",
                // "-d", "-1"
                "-rollout_dir", "experiments/debug_gather_rollouts"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Eval Thresholds Coinrun OOD AE",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/eval_thresholds.py",
            "args": [
                "-wandb_project", "yrc-debug",
                // "-wandb_mode", "offline",
                // "-c", "configs/procgen_ae.yaml",
                // "-c", "configs/procgen_random_hard.yaml",
                "-c", "configs/procgen_ood.yaml",
                "-n", "debug_ood_deepsvdd",
                // "-en", "coinrun",
                "-en", "coinrun",
                "-sim", "YRC/checkpoints/procgen/coinrun/sim_weak/model_40009728.pth",
                "-weak", "YRC/checkpoints/procgen/coinrun/weak/model_80019456.pth",
                "-strong", "YRC/checkpoints/procgen/coinrun/strong/model_200015872.pth",
                // "-cp_method", "Autoencoder",
                "-cp_method", "DeepSVDD",
                "-cp_feature", "obs",
                "-f_n", "trained.joblib",
                "-query_cost", "0",
                "-threshold_bins", "5",
                "-over",
                "-seed", "1",
                "-test_episodes", "64"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Random Eval Thresholds Coinrun",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/eval_thresholds.py",
            "args": [
                "-wandb_project", "yrc-debug",
                // "-wandb_mode", "offline",
                // "-c", "configs/procgen_ae.yaml",
                // "-c", "configs/procgen_random_hard.yaml",
                "-c", "configs/procgen_random.yaml",
                "-n", "debug_random",
                // "-en", "coinrun",
                "-en", "coinrun",
                "-sim", "YRC/checkpoints/procgen/coinrun/sim_weak/model_40009728.pth",
                "-weak", "YRC/checkpoints/procgen/coinrun/weak/model_80019456.pth",
                "-strong", "YRC/checkpoints/procgen/coinrun/strong/model_200015872.pth",
                // "-cp_method", "Autoencoder",
                "-cp_feature", "obs",
                "-query_cost", "0",
                "-threshold_bins", "5",
                "-over",
                "-seed", "1",
                "-test_episodes", "8"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        
    ]
} 